# =============================================================================
# IncidentIQ — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
DEBUG=true
APP_SECRET_KEY=change-me-in-production-use-32-char-random-string

# ---------------------------------------------------------------------------
# MongoDB Atlas
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=incidentiq

# ---------------------------------------------------------------------------
# Groq API
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-70b-8192

# ---------------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DIMENSIONS=384
VECTOR_INDEX_NAME=incidentiq_vector_index

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=/tmp/incidentiq/uploads
MAX_FILE_SIZE_MB=50

# ---------------------------------------------------------------------------
# CORS 
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Frontend (apps/frontend/.env.local)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
